# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/configruntime"

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-random-string-of-at-least-32-characters"

# ─── Backend ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CONFIG_PATH=../config/app.config.json

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Leave empty in development to use Ethereal (fake SMTP) — view emails at ethereal.email
# In production, set all four:
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ─── Optional: Google OAuth ───────────────────────────────────────────────────
# Required if auth.providers includes "google"
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Docker / Production ─────────────────────────────────────────────────────
# Used by docker-compose.yml
POSTGRES_USER=configruntime
POSTGRES_PASSWORD=configruntime_secret
POSTGRES_DB=configruntime

# ─── Log Level ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
